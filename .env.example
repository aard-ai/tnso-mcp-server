# --- TNSO SDMX API ---
TNSO_API_BASE_URL=https://ns1-stathub.nso.go.th/rest
TNSO_AGENCY=TNSO
API_TIMEOUT_SECONDS=30
AVAILABLECONSTRAINT_TIMEOUT_SECONDS=180
API_MAX_RETRIES=3
# Upper bound (seconds) for the out-of-process concept lookup (get_concepts).
CONCEPT_LOOKUP_TIMEOUT_SECONDS=120

# --- Empty-result recovery (get_data / check_data_availability) ---
# Max single-dimension relaxation probes issued when a query returns no rows.
PROBE_MAX_CANDIDATES=3
# Observations per series fetched by a probe (trims the payload). Set to 0 to
# disable the firstNObservations optimization if the endpoint rejects it.
PROBE_FIRST_N_OBSERVATIONS=1

# --- Cache ---
PERSISTENT_CACHE_DIR=./cache
MEMORY_CACHE_TTL_SECONDS=300
MAX_MEMORY_CACHE_ITEMS=512
DATAFLOWS_CACHE_TTL_SECONDS=604800      # 7 days
METADATA_CACHE_TTL_SECONDS=2592000      # 30 days
OBSERVED_DATA_CACHE_TTL_SECONDS=86400   # 1 day

# --- Logging ---
LOG_DIR=./log
LOG_LEVEL=INFO

# Optional: comma-separated dataflow IDs to hide from discover_dataflows / get_data
DATAFLOW_BLACKLIST=

# Optional: path to a CA bundle if your network intercepts TLS (else system default).
# In some sandboxes you may need to point this at the proxy CA bundle.
# SSL_CERT_FILE=/root/.ccr/ca-bundle.crt
